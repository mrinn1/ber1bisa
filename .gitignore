# .gitignore file

# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS
.DS_Store
.AppleDouble
.LSOverride
*.cab
*.msi
*.msix
*.msm
.vscode-test

# Build outputs
dist/
build/
*.out

# Test coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Cache
.cache/
.eslintcache

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Local development
.local/
local/

# Misc
.history/
*.bak
*.swp
*~

# Keep data files
!data/
!data/*.json
