# Example Environment Variables

# For local development and reference
# NEVER commit real API keys!

# Clash of Clans API Key
# Get from: https://developer.clashofclans.com
# Format: Long alphanumeric string
COC_KEY=your_api_key_here_keep_secret

# Clan Tag (example)
# Format: #XXXXXXXX (8 characters)
# Get from: In-game, open clan info
CLAN_TAG=#2PQ2QQUL2

# Node Environment
NODE_ENV=production

# API Configuration (optional)
API_BASE_URL=https://api.clashofclans.com/v1
API_TIMEOUT=10000

# Schedule (cron format)
# */5 * * * * = every 5 minutes
SCHEDULE=*/5 * * * *

# Logging
LOG_LEVEL=info
